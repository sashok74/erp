{
  "info": {
    "name": "ERP Warehouse",
    "description": "Warehouse BC — full regression suite.\nSelf-contained: own auth setup, happy path, negative cases, viewer matrix.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Auth Setup (warehouse_operator)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.test('token exists', function () { pm.expect(json.token).to.be.a('string').and.not.empty; });",
              "pm.environment.set('token', json.token);",
              "pm.environment.set('tenant_id', json.tenant_id);",
              "pm.environment.set('wh_sku', 'WH-' + Date.now());"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"roles\": [\"warehouse_operator\"]\n}" },
        "url": { "raw": "{{base_url}}/dev/token", "host": ["{{base_url}}"], "path": ["dev", "token"] }
      },
      "response": []
    },
    {
      "name": "Receive Goods",
