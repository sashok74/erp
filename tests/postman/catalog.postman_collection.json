    {
      "name": "Get Product (SKU 1)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.test('product payload', function () { pm.expect(json.sku).to.eql(pm.environment.get('catalog_sku_1')); pm.expect(json.name).to.exist; });"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": {
          "raw": "{{base_url}}/api/catalog/products?sku={{catalog_sku_1}}",
          "host": ["{{base_url}}"],
          "path": ["api", "catalog", "products"],
          "query": [{ "key": "sku", "value": "{{catalog_sku_1}}" }]
        }
      },
      "response": []
    },
