              "pm.test('balance query ok', function () { pm.expect(json.sku).to.eql(pm.environment.get('ci_sku')); pm.expect(json.balance).to.exist; });"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": {
          "raw": "{{base_url}}/api/warehouse/balance?sku={{ci_sku}}",
          "host": ["{{base_url}}"],
          "path": ["api", "warehouse", "balance"],
          "query": [{ "key": "sku", "value": "{{ci_sku}}" }]
        }
      },
      "response": []
    },
