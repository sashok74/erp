              "pm.environment.set('token', json.token);",
              "pm.environment.set('tenant_id', json.tenant_id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"tenant_id\": \"{{tenant_id}}\",\n  \"roles\": [\"warehouse_operator\"]\n}" },
        "url": { "raw": "{{base_url}}/dev/token", "host": ["{{base_url}}"], "path": ["dev", "token"] }
      },
      "response": []
    },
    {
      "name": "Receive Goods (CI SKU)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () { pm.response.to.have.status(200); });",
              "var json = pm.response.json();",
              "pm.test('receive ok', function () { pm.expect(json.new_balance).to.exist; pm.expect(json.doc_number).to.exist; });"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{token}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": { "mode": "raw", "raw": "{\n  \"sku\": \"{{ci_sku}}\",\n  \"quantity\": 25\n}" },
        "url": { "raw": "{{base_url}}/api/warehouse/receive", "host": ["{{base_url}}"], "path": ["api", "warehouse", "receive"] }
      },
      "response": []
    },
    {
