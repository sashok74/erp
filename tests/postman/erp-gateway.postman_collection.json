{
	"info": {
		"name": "ERP Gateway",
		"description": "ERP Gateway API — Catalog + Warehouse BCs.\n\nПорядок использования:\n1. POST /dev/token → получить JWT\n2. Токен автоматически сохраняется в переменную {{token}}\n3. Остальные запросы используют Bearer {{token}}\n\nCross-context flow:\n  Create Product (Catalog) → relay → projection (Warehouse) → enriched GetBalance",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://192.168.7.128:3000"
		},
		{
			"key": "token",
			"value": ""
		},
		{
			"key": "tenant_id",
			"value": "019604a0-0000-7000-8000-000000000001"
		}
	],
	"item": [
		{
			"name": "Health",
			"item": [
				{
					"name": "Health Check",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/health",
							"host": ["{{base_url}}"],
							"path": ["health"]
						},
						"description": "Проверка доступности сервера. Без аутентификации."
					},
					"response": []
				}
			]
		},
		{
			"name": "Dev",
			"item": [
				{
					"name": "Issue Token (warehouse_operator)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('token', json.token);",
									"    pm.collectionVariables.set('tenant_id', json.tenant_id);",
									"    console.log('Token saved, tenant_id: ' + json.tenant_id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"tenant_id\": \"{{tenant_id}}\",\n    \"roles\": [\"warehouse_operator\"]\n}"
						},
						"url": {
							"raw": "{{base_url}}/dev/token",
							"host": ["{{base_url}}"],
							"path": ["dev", "token"]
						},
						"description": "Выдать JWT для тестирования. Требует DEV_MODE=1.\nТокен автоматически сохраняется в переменную {{token}}."
					},
					"response": []
				},
				{
					"name": "Issue Token (admin)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('token', json.token);",
									"    pm.collectionVariables.set('tenant_id', json.tenant_id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"tenant_id\": \"{{tenant_id}}\",\n    \"roles\": [\"admin\"]\n}"
						},
						"url": {
							"raw": "{{base_url}}/dev/token",
							"host": ["{{base_url}}"],
							"path": ["dev", "token"]
						},
						"description": "Выдать JWT с ролью admin."
					},
					"response": []
				},
				{
					"name": "Issue Token (catalog_manager)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('token', json.token);",
									"    pm.collectionVariables.set('tenant_id', json.tenant_id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"tenant_id\": \"{{tenant_id}}\",\n    \"roles\": [\"catalog_manager\"]\n}"
						},
						"url": {
							"raw": "{{base_url}}/dev/token",
							"host": ["{{base_url}}"],
							"path": ["dev", "token"]
						},
						"description": "Выдать JWT с ролью catalog_manager."
					},
					"response": []
				},
				{
					"name": "Issue Token (viewer — no write access)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('token', json.token);",
									"    pm.collectionVariables.set('tenant_id', json.tenant_id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"tenant_id\": \"{{tenant_id}}\",\n    \"roles\": [\"viewer\"]\n}"
						},
						"url": {
							"raw": "{{base_url}}/dev/token",
							"host": ["{{base_url}}"],
							"path": ["dev", "token"]
						},
						"description": "Выдать JWT с ролью viewer (нет доступа к warehouse write)."
					},
					"response": []
				}
			]
		},
		{
			"name": "Warehouse",
			"item": [
				{
					"name": "Receive Goods",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"sku\": \"BOLT-42\",\n    \"quantity\": 100\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/warehouse/receive",
							"host": ["{{base_url}}"],
							"path": ["api", "warehouse", "receive"]
						},
						"description": "Приёмка товара на склад.\nТребует роль: warehouse_operator, warehouse_manager или admin.\nВозвращает: item_id, movement_id, new_balance, doc_number."
					},
					"response": []
				},
				{
					"name": "Receive Goods (second batch)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"sku\": \"BOLT-42\",\n    \"quantity\": 50\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/warehouse/receive",
							"host": ["{{base_url}}"],
							"path": ["api", "warehouse", "receive"]
						},
						"description": "Повторная приёмка — баланс накапливается (100 + 50 = 150)."
					},
					"response": []
				},
				{
					"name": "Receive Goods (new SKU)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"sku\": \"NUT-7\",\n    \"quantity\": 200\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/warehouse/receive",
							"host": ["{{base_url}}"],
							"path": ["api", "warehouse", "receive"]
						},
						"description": "Приёмка другого товара — создаётся новый InventoryItem."
					},
					"response": []
				},
				{
					"name": "Get Balance (BOLT-42)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/warehouse/balance?sku=BOLT-42",
							"host": ["{{base_url}}"],
							"path": ["api", "warehouse", "balance"],
							"query": [
								{
									"key": "sku",
									"value": "BOLT-42"
								}
							]
						},
						"description": "Запрос текущего баланса по SKU."
					},
					"response": []
				},
				{
					"name": "Get Balance (NUT-7)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/warehouse/balance?sku=NUT-7",
							"host": ["{{base_url}}"],
							"path": ["api", "warehouse", "balance"],
							"query": [
								{
									"key": "sku",
									"value": "NUT-7"
								}
							]
						},
						"description": "Баланс другого товара."
					},
					"response": []
				},
				{
					"name": "Get Balance (non-existent SKU)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/warehouse/balance?sku=DOES-NOT-EXIST",
							"host": ["{{base_url}}"],
							"path": ["api", "warehouse", "balance"],
							"query": [
								{
									"key": "sku",
									"value": "DOES-NOT-EXIST"
								}
							]
						},
						"description": "Несуществующий SKU — вернёт balance=0, item_id=null."
					},
					"response": []
				}
			]
		},
		{
			"name": "Catalog",
			"item": [
				{
					"name": "Create Product (BOLT-42)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"sku\": \"BOLT-42\",\n    \"name\": \"Болт М8\",\n    \"category\": \"Метизы\",\n    \"unit\": \"шт\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/catalog/products",
							"host": ["{{base_url}}"],
							"path": ["api", "catalog", "products"]
						},
						"description": "Создать товар в каталоге.\nТребует роль: catalog_manager или admin.\nТриггерит ProductCreated event → warehouse projection."
					},
					"response": []
				},
				{
					"name": "Create Product (NUT-7)",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" },
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"sku\": \"NUT-7\",\n    \"name\": \"Гайка М7\",\n    \"category\": \"Метизы\",\n    \"unit\": \"шт\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/catalog/products",
							"host": ["{{base_url}}"],
							"path": ["api", "catalog", "products"]
						},
						"description": "Создать второй товар."
					},
					"response": []
				},
				{
					"name": "Get Product (BOLT-42)",
					"request": {
						"method": "GET",
						"header": [
							{ "key": "Authorization", "value": "Bearer {{token}}" }
						],
						"url": {
							"raw": "{{base_url}}/api/catalog/products?sku=BOLT-42",
							"host": ["{{base_url}}"],
							"path": ["api", "catalog", "products"],
							"query": [{ "key": "sku", "value": "BOLT-42" }]
						},
						"description": "Получить товар по SKU из каталога."
					},
					"response": []
				}
			]
		},
		{
			"name": "Error Cases",
			"item": [
				{
					"name": "Receive without auth → 401",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"sku\": \"BOLT-42\",\n    \"quantity\": 100\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/warehouse/receive",
							"host": ["{{base_url}}"],
							"path": ["api", "warehouse", "receive"]
						},
						"description": "Без Authorization header → 401 Unauthorized."
					},
					"response": []
				},
				{
					"name": "Receive with invalid token → 401",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer invalid.token.here"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"sku\": \"BOLT-42\",\n    \"quantity\": 100\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/warehouse/receive",
							"host": ["{{base_url}}"],
							"path": ["api", "warehouse", "receive"]
						},
						"description": "Невалидный JWT → 401."
					},
					"response": []
				},
				{
					"name": "Receive with viewer role → 403",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"sku\": \"BOLT-42\",\n    \"quantity\": 100\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/warehouse/receive",
							"host": ["{{base_url}}"],
							"path": ["api", "warehouse", "receive"]
						},
						"description": "Сначала выполнить 'Issue Token (viewer)', затем этот запрос.\nViewer не имеет права warehouse.receive_goods → 403."
					},
					"response": []
				},
				{
					"name": "Receive with empty SKU → 400",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"sku\": \"\",\n    \"quantity\": 100\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/warehouse/receive",
							"host": ["{{base_url}}"],
							"path": ["api", "warehouse", "receive"]
						},
						"description": "Пустой SKU → 400 Validation Error."
					},
					"response": []
				},
				{
					"name": "Receive with zero quantity → 400",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"sku\": \"BOLT-42\",\n    \"quantity\": 0\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/warehouse/receive",
							"host": ["{{base_url}}"],
							"path": ["api", "warehouse", "receive"]
						},
						"description": "Нулевое количество → 400 Validation Error."
					},
					"response": []
				},
				{
					"name": "Receive with negative quantity → 400",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							},
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"sku\": \"BOLT-42\",\n    \"quantity\": -10\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/warehouse/receive",
							"host": ["{{base_url}}"],
							"path": ["api", "warehouse", "receive"]
						},
						"description": "Отрицательное количество → 400 Validation Error."
					},
					"response": []
				}
			]
		}
	]
}
